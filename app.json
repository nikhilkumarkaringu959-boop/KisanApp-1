{
  "expo": {
    "name": "KISAN - Smart Farming",
    "slug": "KisanApp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "kisan",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1B5E20"
    },
    "android": {
      "package": "com.karingunikhil.kisan",
      "permissions": ["ACCESS_COARSE_LOCATION", "ACCESS_FINE_LOCATION"]
    },
    "plugins": [
      "expo-router",
      ["expo-location", {
        "locationAlwaysAndWhenInUsePermission": "Allow KISAN to use your location for weather updates."
      }]
    ]
  }
}, 
    "extra": {
      "eas": {
        "projectId": "ec826a31-8491-436e-9"
      }
    }
  }
}
