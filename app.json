{
  "expo": {
    "name": "KISAN - Smart Farming",
    "slug": "kisanapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/icon.png",
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      "expo-location"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.karingunikhil.kisanapp",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "We need your location to show weather and nearby mandi prices"
      }
    },
    "android": {
      "package": "com.karingunikhil.kisanapp",
      "versionCode": 1,
      "newArchEnabled": false,
      "jsEngine": "hermes",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA",
        "READ_MEDIA_IMAGES"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "owner": "nikhilkumarkaringu929s-team",
    "extra": {
      "eas": {
        "projectId": "2a09e627-04f2-4bf1-a145-c86ae9318d11"
      }
    }
  }
}
