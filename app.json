{
  "expo": {
    "name": "KISAN - Smart Farming",
    "slug": "kisanapp",
    "version": "1.0.0",
    "sdkVersion": "51.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "kisan",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.karingunikhil.kisan",
      "buildNumber": "1"
    },
    "android": {
      "package": "com.karingunikhil.kisan",
      "versionCode": 1,
      "backgroundColor": "#1B5E20"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "KISAN app needs location for weather and crop suggestions"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "ec826a31-8491-436e-9951-da6ed6345e02"
      }
    }
  }
}
